rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, ['admin', 'respondent'])
    //   - createdAt: timestamp (required)
    //
    // Collection: surveys
    // Fields:
    //   - title: string (required)
    //   - description: string
    //   - is_public: bool
    //   - is_enumerator: bool
    //   - language: string
    //   - createdBy: string (uid)
    //   - createdAt: timestamp
    //
    // Collection: questions
    // Fields:
    //   - surveyId: string
    //   - text: string
    //   - type: string (['mcq', 'text', 'date', 'number', 'time'])
    //   - order: int
    //   - required: bool
    //
    // Collection: options
    // Fields:
    //   - questionId: string
    //   - text: string
    //   - nextQuestionOrder: int
    //
    // Collection: responses
    // Fields:
    //   - userId: string
    //   - enumeratorUsername: string
    //   - groupUsername: string
    //   - submissionId: string
    //   - surveyId: string
    //   - questionId: string
    //   - answer: string
    //   - submittedAt: timestamp
    //
    // Collection: assignments
    // Fields:
    //   - userId: string
    //   - surveyId: string
    //   - assignedAt: timestamp
    //
    // Collection: projects
    // Fields:
    //   - name: string
    //   - description: string
    //   - createdBy: string
    //   - createdAt: timestamp
    //
    // Collection: project_assignments
    // Fields:
    //   - userId: string
    //   - projectId: string
    //   - role: string
    //   - assignedAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "rannamaari@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isProjectMember(projectId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/project_assignments/$(request.auth.uid + '_' + projectId));
    }

    function isSurveyProjectMember(surveyId) {
      let survey = get(/databases/$(database)/documents/surveys/$(surveyId)).data;
      return survey.projectId != null && isProjectMember(survey.projectId);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'role', 'createdAt', 'username', 'uid']) &&
             data.email is string &&
             data.role in ['admin', 'respondent'];
    }

    function isValidSurvey(data) {
      return hasOnlyAllowedFields(['title', 'description', 'is_public', 'is_enumerator', 'language', 'createdBy', 'createdAt', 'isActive', 'is_group', 'allow_multiple_submissions', 'projectId']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200;
    }

    function isValidProject(data) {
      return hasOnlyAllowedFields(['name', 'description', 'createdBy', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200;
    }

    function isValidProjectAssignment(data) {
      return hasOnlyAllowedFields(['userId', 'projectId', 'role', 'assignedAt']) &&
             data.userId is string && data.projectId is string && data.role in ['member', 'manager'];
    }

    function isValidResponse(data) {
      return hasOnlyAllowedFields(['userId', 'enumeratorUsername', 'submissionId', 'surveyId', 'questionId', 'answer', 'submittedAt', 'groupUsername']) &&
             (data.userId == null || data.userId is string) &&
             (data.enumeratorUsername == null || data.enumeratorUsername is string) &&
             (data.groupUsername == null || data.groupUsername is string) &&
             data.answer is string && data.answer.size() < 5000 &&
             data.surveyId is string && data.questionId is string && data.submissionId is string &&
             data.submittedAt is timestamp;
    }

    function isValidQuestion(data) {
      return hasOnlyAllowedFields(['surveyId', 'text', 'type', 'order', 'required', 'updatedAt']) &&
             data.surveyId is string && data.text is string && data.type is string && data.order is int;
    }

    function isValidOption(data) {
      return hasOnlyAllowedFields(['questionId', 'surveyId', 'text', 'nextQuestionOrder']) &&
             data.questionId is string && data.surveyId is string && data.text is string &&
             (!('nextQuestionOrder' in data) || data.nextQuestionOrder == null || data.nextQuestionOrder is int);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'respondent') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /surveys/{surveyId} {
      allow read: if isAuthenticated() || resource.data.is_public == true || resource.data.is_enumerator == true || resource.data.is_group == true;
      allow create: if (isAdmin() || (isAuthenticated() && request.resource.data.projectId != null && isProjectMember(request.resource.data.projectId))) && isValidSurvey(request.resource.data);
      allow update: if (isAdmin() || (isAuthenticated() && resource.data.projectId != null && isProjectMember(resource.data.projectId))) && isValidSurvey(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.projectId != null && isProjectMember(resource.data.projectId));
    }

    match /projects/{projectId} {
      allow read: if isAdmin() || isProjectMember(projectId);
      allow create, update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /project_assignments/{assignmentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create, update: if isAdmin() && isValidProjectAssignment(request.resource.data);
      allow delete: if isAdmin();
    }

    match /surveys/{surveyId}/enumerator_users/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /surveys/{surveyId}/group_users/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{path=**}/enumerator_users/{userId} {
      allow read: if true;
    }

    match /{path=**}/group_users/{userId} {
      allow read: if true;
    }

    match /questions/{questionId} {
      allow read: if true;
      allow create, update: if (isAdmin() || isSurveyProjectMember(request.resource.data.surveyId)) && isValidQuestion(request.resource.data);
      allow delete: if isAdmin() || isSurveyProjectMember(resource.data.surveyId);
    }

    match /options/{optionId} {
      allow read: if true;
      allow create, update: if (isAdmin() || isSurveyProjectMember(request.resource.data.surveyId)) && isValidOption(request.resource.data);
      allow delete: if isAdmin() || isSurveyProjectMember(resource.data.surveyId);
    }

    match /responses/{responseId} {
      allow read: if isAdmin() || 
                  (isAuthenticated() && resource.data.userId == request.auth.uid) ||
                  (get(/databases/$(database)/documents/surveys/$(resource.data.surveyId)).data.is_public == true) ||
                  (get(/databases/$(database)/documents/surveys/$(resource.data.surveyId)).data.is_enumerator == true) ||
                  (get(/databases/$(database)/documents/surveys/$(resource.data.surveyId)).data.is_group == true);
      allow create: if isValidResponse(request.resource.data) && (
                      (isAuthenticated() && request.resource.data.userId == request.auth.uid) || 
                      (get(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.is_public == true) ||
                      (get(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.is_enumerator == true) ||
                      (get(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.is_group == true)
                    );
      allow update, delete: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
