{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "respondent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Survey": {
      "title": "Survey",
      "description": "A survey containing multiple questions",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "is_public": { "type": "boolean" },
        "is_enumerator": { "type": "boolean" },
        "allow_multiple_submissions": { "type": "boolean" },
        "language": { "type": "string" },
        "projectId": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "createdBy", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A project that can contain multiple surveys",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdBy", "createdAt"]
    },
    "ProjectAssignment": {
      "title": "ProjectAssignment",
      "description": "Mapping of a user to a project",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "role": { "type": "string", "enum": ["member", "manager"] },
        "assignedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "projectId", "assignedAt"]
    },
    "Question": {
      "title": "Question",
      "description": "A question within a survey",
      "type": "object",
      "properties": {
        "surveyId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["mcq", "text", "date", "number", "time"] },
        "order": { "type": "integer" },
        "required": { "type": "boolean" }
      },
      "required": ["surveyId", "text", "type", "order"]
    },
    "Option": {
      "title": "Option",
      "description": "An option for a multiple choice question",
      "type": "object",
      "properties": {
        "questionId": { "type": "string" },
        "text": { "type": "string" },
        "nextQuestionOrder": { "type": "integer" }
      },
      "required": ["questionId", "text"]
    },
    "Response": {
      "title": "Response",
      "description": "A user's answer to a question",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "submissionId": { "type": "string" },
        "surveyId": { "type": "string" },
        "questionId": { "type": "string" },
        "answer": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["submissionId", "surveyId", "questionId", "answer", "submittedAt"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Mapping of a survey to a respondent",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "surveyId": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "surveyId", "assignedAt"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Application settings",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "value", "updatedAt"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "surveys": { "schema": "Survey", "description": "Survey definitions" },
    "questions": { "schema": "Question", "description": "Questions for surveys" },
    "options": { "schema": "Option", "description": "Options for MCQ questions" },
    "responses": { "schema": "Response", "description": "User survey responses" },
    "assignments": { "schema": "Assignment", "description": "Survey assignments to users" },
    "projects": { "schema": "Project", "description": "Project definitions" },
    "project_assignments": { "schema": "ProjectAssignment", "description": "Project assignments to users" },
    "settings": { "schema": "Setting", "description": "Application settings" }
  }
}
